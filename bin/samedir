#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<USAGE
Usage: $0 COMMAND [ARG…]
   or: $0 --print
   or: $0 --debug

Tries to run COMMAND in the same CWD as the currently focused window. Will
start in \$HOME if CWD cannot be determined.

With --print option, no command will run. Instead the path that would be used
as CWD for a command is printed to stdout.

With the --debug option, much more output will be printed. It will print a list
of all checked processes.
USAGE
}

mode=run
default="$HOME"

if [[ $1 == "--help" ]]; then
  usage
  exit 0
elif [[ $# -le 0 ]]; then
  usage >&2
  exit 1
elif [[ $# -eq 1 ]] && [[ $1 == "--print" ]]; then
  mode=print
  shift
elif [[ $# -eq 1 ]] && [[ $1 == "--debug" ]]; then
  mode=debug
  shift
fi

function detect_xorg_pid() {
  xprop -id "$(xprop -root | awk '/_NET_ACTIVE_WINDOW\(WINDOW\)/{print $NF}')" |
    grep -m 1 PID |
    cut -d " " -f 3
}

function detect_hyprland_pid() {
  hyprctl activewindow | grep 'pid:' | cut -d " " -f 2
}

function detect_niri_pid() {
  # If no window is focused, this returns "null". Default that to empty
  # string since that is easier to test against in shell scripts.
  niri msg -j focused-window | jq -r '.pid // ""'
}

function detect_pid() {
  local pid
  if [[ "$XDG_CURRENT_DESKTOP" == "niri" ]]; then
    pid="$(detect_niri_pid)"
  elif [[ "$XDG_CURRENT_DESKTOP" == "Hyprland" ]]; then
    pid="$(detect_hyprland_pid)"
  else
    detect_xorg_pid
    return
  fi

  # If PID points to xwayland-satellite, check the nested window's PID instead.
  if [[ -n "$pid" ]] && [[ "$(readlink /proc/"$pid"/exe)" == *xwayland-satellite* ]]; then
    pid="$(detect_xorg_pid)"
  fi

  echo "$pid"
}

# List all pids running in this window; for example a terminal might be running
# a shell that is running an editor.
function ancestor_pids() {
  local pid="$1"

  if [[ -z "$pid" ]]; then
    return
  fi

  # -T hides threads so we can focus on processes only.
  # -p shows pid.
  # -A uses ASCII trees, so it's easier to split the list and pick the last process.
  #
  # pstree might look like this:
  # kitty(21645)---zsh(21650)-+-cat(27539)
  #                           `-samedir(27538)---pstree(27547)
  #
  pstree -lpAT "$pid" |
    # Use sed to split it so at most one process is on each line, then strip out
    # everything that isn't a number.
    sed -Ee 's/-.-/\n/g' -e 's/[^0-9\n]*//g' |
    # Then use tac to reverse the order.
    tac
}

function cwd_of_pid() {
  local pid="$1"

  if dir="$(readlink /proc/"$pid"/cwd)"; then
    # Some dirs we don't want to find.
    case "$dir" in
    /run/user/*/firenvim | /proc/*)
      return 1
      ;;
    *)
      echo "$dir"
      ;;
    esac
  else
    return 1
  fi
}

function name_of_pid() {
  local pid="$1"
  cat 2>/dev/null /proc/"$pid"/comm || echo "[unknown]"
}

function exec_in_dir() {
  local dir="$1"
  shift

  if [[ -z "$dir" ]]; then
    dir="$default"
  fi

  cd "$dir" && exec "$@"
}

function main() {
  # Find PID of active window
  pid=$(detect_pid)

  if [[ -z "$pid" ]]; then
    exec_in_dir "$default" "$@"
  fi

  # There's always a risk that the deepest process is short-lived (maybe it's
  # running this script itself after all.
  # Iterate each process (but in reverse order) until a working CWD is
  # found.
  pids=$(ancestor_pids "$pid")

  while read -r pid; do
    [[ -z "$pid" ]] && continue

    if dir="$(cwd_of_pid "$pid")"; then
      case "$mode" in
      run)
        exec_in_dir "$dir" "$@"
        ;;
      print)
        echo "$dir"
        exit 0
        ;;
      debug)
        echo "$pid ($(name_of_pid "$pid")): $dir"
        ;;
      esac
    elif [[ $mode == "debug" ]]; then
      echo "$pid ($(name_of_pid "$pid")) gone"
    fi
  done <<<"$pids"

  case "$mode" in
  debug)
    echo "default: $default"
    exit 0
    ;;
  print)
    echo "$default"
    exit 0
    ;;
  run)
    exec_in_dir "$default" "$@"
    ;;
  esac
}

main "$@"
